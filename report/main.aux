\newlabel{fig:sw-spectral}{{6}{13}{Internal structure of a \texttt {SpectralReweightingLayer} for head $h$ of block $(\ell , b)$. \textbf {Right} (\emph {fitting pass}): $N_{\mathrm {clips}}$ per-head activation matrices are concatenated to form the fitting matrix $\widetilde {\mathbf {R}}_{\ell ,b,h}$ (Eq.~\eqref {eq:fitting_matrix}), from which the empirical mean $\boldsymbol {\mu }_{\ell ,b,h}$ and PCA basis $\boldsymbol {\Phi }_{\ell ,b,h}$ are estimated (Eq.~\eqref {eq:pca_decomp}), and the initial weight vector $\boldsymbol {\lambda }^{(0)}_{\ell ,b,h}$ is set via the variance-threshold criterion (Eqs.~\eqref {eq:k_threshold}--\eqref {eq:lambda_init}). \textbf {Centre} (\emph {spectral reweighting}): at inference time the four-step transform centres, projects onto the PCA basis, rescales per component, and reconstructs each head tensor (Eqs.~\eqref {eq:rd_reweight-1}--\eqref {eq:rd_star}). \textbf {Bottom-right} (\emph {optimisation}): the weight vector $\boldsymbol {\lambda }_{\ell ,b,h}$ is refined by minimising $\mathcal {J}$ on additional training samples (\S \ref {app:optim})}{figure.caption.11}{}}
\newlabel{app:fitting}{{C.2}{13}{}{subsection.C.2}{}}
\newlabel{fig:sw-mha-window}{{7}{14}{Reweighting pipeline for a single target block $(\ell , b)$. The \texttt {WindowAttention} module computes the raw per-head tensors $\mathbf {H}_{\ell ,b,h} \in \mathbb {R}^{N_w^\ell \times M \times d_h}$ via the standard scaled dot-product attention with relative position bias $\mathbf {B}_{\ell ,b,h}$. PyTorch \texttt {AttentionHooks} intercept each $\mathbf {H}_{\ell ,b,h}$ and route it through the corresponding \texttt {SpectralReweightingLayer}; the reweighted outputs $\mathbf {H}^*_{\ell ,b,h}$ are then stacked, reshaped, and projected by $W^O_{\ell ,b}$ to yield the block output $\mathbf {Z}^{(\ell ,b)}_{\mathrm {out}} \in \mathbb {R}^{N_w^\ell \times M \times D_\ell }$}{figure.caption.12}{}}
\newlabel{eq:fitting_matrix}{{31}{14}{}{equation.C.31}{}}
\newlabel{eq:pca_decomp}{{33}{14}{}{equation.C.33}{}}
\newlabel{eq:k_threshold}{{36}{14}{}{equation.C.36}{}}
\newlabel{eq:lambda_init}{{37}{14}{}{equation.C.37}{}}
